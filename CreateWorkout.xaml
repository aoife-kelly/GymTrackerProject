<Window x:Class="gymTracker.CreateWorkout"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:gymTracker"
        mc:Ignorable="d"
        Title="CreateWorkout"
        Height="844"
        Width="390"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>

    </Window.Resources>

    <Grid Background="White">

        <!-- stacking everything -->
        <Grid.RowDefinitions>
            <RowDefinition Height="70" />
            <!-- header -->
            <RowDefinition Height="Auto" />
            <!-- workout name/save -->
            <RowDefinition Height="Auto" />
            <!-- search bar -->
            <RowDefinition Height="*" />
            <!-- rest of the area left -->
        </Grid.RowDefinitions>

        <!-- header -->
        <Border Grid.Row="0"
                Style="{StaticResource HeaderBar}">

            <Button x:Name="menuBackBtn"
                    Content="Back"
                    Style="{StaticResource WhiteRoundedButton}"
                    Width="70"
                    Height="40"
                    Margin="20,15,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Click="menuBackBtn_Click" />
        </Border>

        <!-- workout name nad save button beside each other -->
        <Grid Grid.Row="1"
              Margin="20,20,20,0"
              VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <!-- takes yp available space -->
                <ColumnDefinition Width="65" />
                <!-- had to change this from 80 bc it looked weird when i ran it -->
            </Grid.ColumnDefinitions>

            <TextBox x:Name="workoutNameTbx"
                     Style="{StaticResource PinkTextBox}"
                     Tag="Enter workout name..."
                     Grid.Column="0"
                     Margin="0,-10,20,10"
                     GotFocus="workoutNameTbx_GotFocus"
                     LostFocus="workoutNameTbx_LostFocus" />

            <Button x:Name="saveBtn"
                    Style="{StaticResource PinkRoundedButton}"
                    Content="Save"
                    Grid.Column="1"
                    Margin="0,-10,0,10"
                    Click="saveBtn_Click" />
        </Grid>

        <!-- search -->
        <Grid Grid.Row="2"
              Margin="20,10,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="65" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="exerciseSearchTbx"
                     Grid.Column="0"
                     Style="{StaticResource PinkTextBox}"
                     Tag="Search..."
                     TextChanged="exerciseSearchTbx_TextChanged"
                     Margin="0,0,10,0"
                     GotFocus="exerciseSearchTbx_GotFocus"
                     LostFocus="exerciseSearchTbx_LostFocus" />

            <Button x:Name="addExerciseBtn"
                    Grid.Column="1"
                    Style="{StaticResource PinkRoundedButton}"
                    Content="Add"
                    Click="addExerciseBtn_Click" />
        </Grid>

        <ListBox x:Name="exercisesLBx"
                 Grid.Row="3"
                 Margin="20,0,20,0"
                 VerticalAlignment="Top"
                 MaxHeight="200"
                 Panel.ZIndex="10"
                 Visibility="Collapsed">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding"
                            Value="10" />
                    <Setter Property="Background"
                            Value="#F0F0F0" />
                    <Setter Property="Margin"
                            Value="0,1" />
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <Label Content="Current Workout:"
               Grid.Row="3"
               Margin="20,40,0,0"
               FontWeight="Bold" />

        <ListBox x:Name="addedExercisesLBx"
                 Grid.Row="3"
                 Margin="20,65,20,20" />

    </Grid>
</Window>