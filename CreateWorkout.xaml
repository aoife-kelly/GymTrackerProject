<Window x:Class="gymTracker.CreateWorkout"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:gymTracker"
        mc:Ignorable="d"
        Title="CreateWorkout" Height="844" Width="390" 
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>

    </Window.Resources>

    <Grid Background="White">

        <!-- stacking everything -->
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/> <!-- header -->
            <RowDefinition Height="Auto"/> <!-- workout name/save -->
            <RowDefinition Height="Auto"/> <!-- search bar -->
            <RowDefinition Height="*"/> <!-- rest of the area left -->
        </Grid.RowDefinitions>

        <!-- header -->
        <Border Grid.Row="0" Style="{StaticResource HeaderBar}">
            
            <Button x:Name="menuBackBtn"
                    Content="Back"
                    Style="{StaticResource WhiteRoundedButton}"
                    Width="70"
                    Height="40"
                    Margin="20,15,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Click="menuBackBtn_Click"/>
        </Border>

        <!-- workout name nad save button beside each other -->
        <Grid Grid.Row="1"
                Margin="20,20,20,0"
                VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/> <!-- takes yp available space -->
                <ColumnDefinition Width="65"/> <!-- had to change this from 80 bc it looked weird when i ran it -->
            </Grid.ColumnDefinitions>

            <TextBox x:Name="workoutNameTbx"
                        Style="{StaticResource PinkTextBox}"
                        Tag="Enter workout name..."
                        Grid.Column="0"
                        Margin="0,-10,20,10" 
                        GotFocus="workoutNameTbx_GotFocus" 
                        LostFocus="workoutNameTbx_LostFocus"/>

            <Button x:Name="saveBtn"
                        Style="{StaticResource PinkRoundedButton}"
                        Content="Save"
                        Grid.Column="1" 
                        Margin="0,-10,0,10" 
                        Click="saveBtn_Click"/>
        </Grid>

        <!-- search -->
        <TextBox x:Name="exerciseSearchTbx"
                    Grid.Row="2"
                    Style="{StaticResource PinkTextBox}"
                    Tag="Search..."
                    Margin="45,10,45,10"
                    GotFocus="exerciseSearchTbx_GotFocus"
                    LostFocus="exerciseSearchTbx_LostFocus"/>

    </Grid>

</Window>